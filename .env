# =============================================================
#  HeartSync Environment Variables
#  Copy this to .env and fill in your own values.
#  NEVER commit this file to Git.
# =============================================================

# --- JWT ---
# Must be at least 32 characters (256-bit) for HMAC-SHA256
JWT_SECRET=heartsync-super-secret-jwt-key-change-in-production-32chars

# --- PostgreSQL: Patient Service ---
PATIENT_DB_NAME=patient_db
PATIENT_DB_USER=patient_user
PATIENT_DB_PASSWORD=patient_pass
PATIENT_DB_PORT=5432

# --- PostgreSQL: IAM Service ---
IAM_DB_NAME=iam_db
IAM_DB_USER=iam_user
IAM_DB_PASSWORD=iam_pass
IAM_DB_PORT=5433

# --- PostgreSQL: ECG Service ---
ECG_DB_NAME=ecg_db
ECG_DB_USER=ecg_user
ECG_DB_PASSWORD=ecg_pass
ECG_DB_PORT=5434

# --- PostgreSQL: Reporting Service ---
REPORTING_DB_NAME=reporting_db
REPORTING_DB_USER=reporting_user
REPORTING_DB_PASSWORD=reporting_pass
REPORTING_DB_PORT=5435

# --- MongoDB: AI Inference Service ---
MONGO_DB_NAME=ai_db
MONGO_ROOT_USER=mongo_admin
MONGO_ROOT_PASSWORD=mongo_pass
MONGO_PORT=27017

# --- RabbitMQ ---
RABBITMQ_USER=heartsync
RABBITMQ_PASSWORD=heartsync_pass
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- MinIO (PDF / image storage) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_pass
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Service Ports ---
EUREKA_PORT=8761
GATEWAY_PORT=8080
PATIENT_SERVICE_PORT=8081
IAM_SERVICE_PORT=8082
ECG_SERVICE_PORT=8083
AI_SERVICE_PORT=8084
REPORTING_SERVICE_PORT=8085
FRONTEND_PORT=3000
